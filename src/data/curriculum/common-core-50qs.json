[{"id":"intro-philosophy","title":"نشأة الفلسفة","description":"Introduction to the origins of philosophy and its distinction from myth.","unlocks":"thales","concepts":[{"id":"myth-logos","name":"من الأسطورة إلى اللوغوس","description":"The transition from mythological thinking to rational philosophical thought in ancient Greece.","content":"Philosophy emerged in ancient Greece as a break from mythological explanations of the world. While myth relies on imagination and narrative, Logos (reason) relies on argument and evidence."},{"id":"nature-culture","name":"الطبيعة والثقافة","description":"Distinguishing between what is natural and what is acquired in human behavior.","content":"Is human behavior determined by instinct (nature) or by education and society (culture)? This is a fundamental question in understanding the human condition."}],"philosopher":{"id":"thales","name":"طاليس","era":"اليونان القديمة (القرن 6 ق.م)","bio":"يعتبر أول فيلسوف في التاريخ. أرجع أصل الكون إلى الماء، متجاوزاً التفسيرات الأسطورية.","quote":"الماء هو المبدأ الأول لكل الأشياء."},"quiz":[{"id":"q1","question":"ما الفرق الأساسي بين الأسطورة والفلسفة؟","options":["الأسطورة تعتمد على الخيال، والفلسفة تعتمد على العقل","الأسطورة تأتي بعد الفلسفة","لا يوجد فرق بينهما","الفلسفة تعتمد على الدين فقط"],"correctAnswer":0,"category":"من الأسطورة إلى اللوغوس"},{"id":"q2","question":"أين نشأت الفلسفة لأول مرة بشكل منهجي؟","options":["مصر القديمة","بلاد الرافدين","اليونان القديمة","الصين"],"correctAnswer":2,"category":"من الأسطورة إلى اللوغوس"},{"id":"q3","question":"ما معنى كلمة 'لوغوس' في الفلسفة اليونانية الأولى؟","options":["الخيال","الكلام والحجة","الدين","الطبيعة"],"correctAnswer":1,"category":"من الأسطورة إلى اللوغوس"},{"id":"q4","question":"من هو أول فيلسوف في التاريخ؟","options":["سقراط","طاليس الميليتي","أفلاطون","أرسطو"],"correctAnswer":1,"category":"من الأسطورة إلى اللوغوس"},{"id":"q5","question":"ما الذي اعتبره طاليس مبدأ الكون الأول؟","options":["النار","الهواء","الماء","الأرض"],"correctAnswer":2,"category":"من الأسطورة إلى اللوغوس"},{"id":"q6","question":"لماذا تجاوزت الفلسفة التفسيرات الأسطورية؟","options":["بالحجج والأدلة","بالقصص الخيالية","بالطقوس الدينية","بالسحر"],"correctAnswer":0,"category":"من الأسطورة إلى اللوغوس"},{"id":"q7","question":"أي مدينة يونانية ارتبطت بطاليس؟","options":["أثينا","ميليتوس","روما","بابل"],"correctAnswer":1,"category":"من الأسطورة إلى اللوغوس"},{"id":"q8","question":"ما 'الآرخي' في الفلسفة الطبيعية الأولى؟","options":["النهاية","المبدأ الأول","الوسط","الفراغ"],"correctAnswer":1,"category":"من الأسطورة إلى اللوغوس"},{"id":"q9","question":"كيف تشرح الأسطورة الطبيعة؟","options":["بالحجة المنطقية","بالخيال والقصة","بالتجربة العلمية","بالرياضيات"],"correctAnswer":1,"category":"من الأسطورة إلى اللوغوس"},{"id":"q10","question":"من هو تلميذ طاليس الذي قال بالهواء؟","options":["أنكسيمندر","أنكسيمينس","هيراقليطس","بارمنيدس"],"correctAnswer":1,"category":"من الأسطورة إلى اللوغوس"},{"id":"q11","question":"هل نشأت الفلسفة في الشرق قبل الغرب؟","options":["نعم في الصين","لا، اليونان أول","نعم في الهند","لا فرق"],"correctAnswer":1,"category":"من الأسطورة إلى اللوغوس"},{"id":"q12","question":"ما دور الخيال في الأسطورة؟","options":["دور ثانوي","الدور الأساسي","لا دور","دور عقلي"],"correctAnswer":1,"category":"من الأسطورة إلى اللوغوس"},{"id":"q13","question":"اللوغوس يعتمد على؟","options":["القصة","الحجة والدليل","الإلهام","الحدس"],"correctAnswer":1,"category":"من الأسطورة إلى اللوغوس"},{"id":"q14","question":"طاليس تنبأ بـ؟","options":["زلزال","حرب","فيضان","مجاعة"],"correctAnswer":0,"category":"من الأسطورة إلى اللوغوس"},{"id":"q15","question":"الفلسفة الطبيعية أولى من الفلسفة الأخلاقية؟","options":["لا","نعم","متساوية","غير معروف"],"correctAnswer":1,"category":"من الأسطورة إلى اللوغوس"},{"id":"q16","question":"من أول من بحث في الطبيعة بالعقل؟","options":["الكلدان","اليونانيون","المصريون","الفرس"],"correctAnswer":1,"category":"من الأسطورة إلى اللوغوس"},{"id":"q17","question":"الأسطورة تشرح الكون كيف؟","options":["بالعقل","بالقصص الرمزية","بالرياضيات","بالتجربة"],"correctAnswer":1,"category":"من الأسطورة إلى اللوغوس"},{"id":"q18","question":"لوغوس يعني؟","options":["نسبة","عقل","قصة","إله"],"correctAnswer":1,"category":"من الأسطورة إلى اللوغوس"},{"id":"q19","question":"طاليس درس في؟","options":["مصر","بابل","الهند","كلها"],"correctAnswer":3,"category":"من الأسطورة إلى اللوغوس"},{"id":"q20","question":"الفلسفة بدأت القرن كم ق.م؟","options":["5","8","6","4"],"correctAnswer":2,"category":"من الأسطورة إلى اللوغوس"},{"id":"q21","question":"هل طاليس كاهن؟","options":["نعم","لا","ربما","غير معروف"],"correctAnswer":0,"category":"من الأسطورة إلى اللوغوس"},{"id":"q22","question":"الأسطورة تعتمد على الـ؟","options":["عقل","برهان","خيال وتخيل","علم"],"correctAnswer":2,"category":"من الأسطورة إلى اللوغوس"},{"id":"q23","question":"اللوغوس هو بداية الفلسفة في ماذا؟","options":["الأخلاق","الطبيعة","الدين","السياسة"],"correctAnswer":1,"category":"من الأسطورة إلى اللوغوس"},{"id":"q24","question":"أنكسيمندر قال بالـ؟","options":["الماء","اللامحدود","الهواء","النار"],"correctAnswer":1,"category":"من الأسطورة إلى اللوغوس"},{"id":"q25","question":"الفلسفة اليونانية تسمى 'حكمة' لأن؟","options":["سعي للمعرفة","قصص أسطورية","سحر","دين"],"correctAnswer":0,"category":"من الأسطورة إلى اللوغوس"},{"id":"q26","question":"ما الطبيعة في سياق الفلسفة؟","options":["الثقافة والتربية","الغريزة والفطرة","الدين والطقوس","العلم الحديث"],"correctAnswer":1,"category":"الطبيعة والثقافة"},{"id":"q27","question":"هل السلوك البشري فطري فقط؟","options":["نعم","لا، مزيج","لا، ثقافي فقط","غير معروف"],"correctAnswer":1,"category":"الطبيعة والثقافة"},{"id":"q28","question":"الثقافة تشكل الإنسان كيف؟","options":["بالغريزة","بالتربية والمجتمع","بالوراثة","بالصدفة"],"correctAnswer":1,"category":"الطبيعة والثقافة"},{"id":"q29","question":"من يحدد السلوك، الطبيعة أم التربية؟","options":["الطبيعة فقط","التربية فقط","كلاهما","لا أحد"],"correctAnswer":2,"category":"الطبيعة والثقافة"},{"id":"q30","question":"في فهم الإنسان، الطبيعة تعني؟","options":["الغريزة والفطرة","الكتب والمدارس","اللغة","الدين"],"correctAnswer":0,"category":"الطبيعة والثقافة"},{"id":"q31","question":"هل الإنسان 'صفحة بيضاء' عند الولادة؟","options":["نعم حسب لوك","لا، لديه غرائز","نعم حسب أفلاطون","لا حسب كانط"],"correctAnswer":1,"category":"الطبيعة والثقافة"},{"id":"q32","question":"الثقافة هي ما هو؟","options":["فطري","مكتسب","وراثي","سماوي"],"correctAnswer":1,"category":"الطبيعة والثقافة"},{"id":"q33","question":"سؤال أساسي عن الإنسان؟","options":["الطبيعة أم الثقافة","السماء أم الأرض","الخير أم الشر","الحياة أم الموت"],"correctAnswer":0,"category":"الطبيعة والثقافة"},{"id":"q34","question":"السلوك الاجتماعي من أين؟","options":["الغريزة","التربية","الجينات","النجوم"],"correctAnswer":1,"category":"الطبيعة والثقافة"},{"id":"q35","question":"الطبيعة تحدد الـ؟","options":["لغة","غرائز وسلوك فطري","دين","قوانين"],"correctAnswer":1,"category":"الطبيعة والثقافة"},{"id":"q36","question":"هل التعليم يغير الفطرة؟","options":["لا","نعم جزئياً","كلياً","لا تأثير"],"correctAnswer":1,"category":"الطبيعة والثقافة"},{"id":"q37","question":"مثال على الطبيعة في الإنسان؟","options":["الكلام","الرضاعة","القراءة","الكتابة"],"correctAnswer":1,"category":"الطبيعة والثقافة"},{"id":"q38","question":"الثقافة تختلف بين؟","options":["الأفراد والمجتمعات","الطبيعة فقط","الجينات","الحيوانات"],"correctAnswer":0,"category":"الطبيعة والثقافة"},{"id":"q39","question":"الفطرة هي؟","options":["ما هو مكتسب","ما هو فطري","الدين","العلم"],"correctAnswer":1,"category":"الطبيعة والثقافة"},{"id":"q40","question":"هل اللغة طبيعية؟","options":["نعم كلياً","لا، مكتسبة","جزئياً","غير معروف"],"correctAnswer":2,"category":"الطبيعة والثقافة"},{"id":"q41","question":"السؤال الفلسفي عن الإنسان يدور حول؟","options":["المال","الطبيعة والثقافة","الرياضة","الأكل"],"correctAnswer":1,"category":"الطبيعة والثقافة"},{"id":"q42","question":"الغريزة مثال على؟","options":["الثقافة","الطبيعة","الدين","الفن"],"correctAnswer":1,"category":"الطبيعة والثقافة"},{"id":"q43","question":"التعليم يؤثر على السلوك كيف