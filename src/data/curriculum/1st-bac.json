[{"id":"humanity","title":"الإنسان","description":"Exploring the dimensions of human existence: Consciousness, Desire, and Language.","unlocks":"freud","concepts":[{"id":"consciousness","name":"الوعي واللاوعي","description":"Understanding the limits of awareness and the role of the unconscious mind.","content":"Is consciousness the only ruler of human life? Freud introduced the concept of the Unconscious to explain behaviors that escape our conscious control."},{"id":"desire","name":"الرغبة","description":"The nature of desire as a lack or a productive force.","content":"Do we desire what we need, or is desire something else entirely? Spinoza argues that desire is the essence of man."}],"philosopher":{"id":"freud","name":"سيغموند فرويد","era":"القرن 19-20","bio":"مؤسس التحليل النفسي. اكتشف أن جزءاً كبيراً من حياتنا النفسية يحكمه 'اللاوعي'.","quote":"الأنا ليس سيداً في بيته."},"quiz":[{"id":"q1","question":"من هو الفيلسوف الذي ارتبط اسمه بمفهوم اللاشعور؟","options":["ديكارت","سيغموند فرويد","أفلاطون","كانط"],"correctAnswer":1,"category":"الوعي واللاوعي"},{"id":"q2","question":"ما العلاقة بين الوعي والإدراك الحسي؟","options":["هما نفس الشيء","الوعي أوسع من الإدراك الحسي","الإدراك الحسي نوع من اللاوعي","لا توجد علاقة"],"correctAnswer":1,"category":"الوعي واللاوعي"},{"id":"q3","question":"من اكتشف مفهوم 'اللاوعي'؟","options":["يونغ","فرويد","أدلر","لاكان"],"correctAnswer":1,"category":"الوعي واللاوعي"},{"id":"q4","question":"اللاوعي يحكم جزءاً كبيراً من؟","options":["السلوك اليومي","الحياة النفسية","الرياضة","الأكل"],"correctAnswer":1,"category":"الوعي واللاوعي"},{"id":"q5","question":"'الأنا ليس سيداً في بيته' لمن؟","options":["نيتشه","فرويد","ماركس","هيجل"],"correctAnswer":1,"category":"الوعي واللاوعي"},{"id":"q6","question":"هل الوعي يسيطر على كل شيء؟","options":["نعم","لا","جزئياً فقط","غير معروف"],"correctAnswer":2,"category":"الوعي واللاوعي"},{"id":"q7","question":"الإدراك الحسي جزء من؟","options":["اللاوعي","الوعي","الخيال","الذاكرة"],"correctAnswer":1,"category"