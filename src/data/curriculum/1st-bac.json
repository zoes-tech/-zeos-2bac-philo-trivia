 واللاوعي"},{"id":"q36","question":"اللغة جزء من الوعي الاجتماعي؟","options":["نعم","لا","فطري","لا علاقة"],"correctAnswer":0,"category":"الوعي واللاوعي"},{"id":"q37","question":"فرويد قال اللاوعي يحكم الحياة النفسية بنسبة كم؟","options":["جزء كبير","صغير","نصف","لا شيء"],"correctAnswer":0,"category":"الوعي واللاوعي"},{"id":"q38","question":"الرغبة تؤدي إلى الإبداع؟","options":["نعم حسب سبينوزا","لا","فقط سلبيات","حسب النوع"],"category":"الرغبة","correctAnswer":0},{"id":"q39","question":"اللاوعي يظهر في الأخطاء اللغوية؟","options":["نعم، فرويد","لا","جزئياً","علمياً"],"correctAnswer":0,"category":"الوعي واللاوعي"},{"id":"q40","question":"الرغبة كـ 'نقص' عند من؟","options":["لاسو","سبينوزا","فرويد","أفلاطون"],"correctAnswer":2,"category":"الرغبة"},{"id":"q41","question":"هل الوعي كلي السيطرة؟","options":["نعم","لا، لاوعي موجود","مطلق","جزئي"],"correctAnswer":1,"category":"الوعي واللاوعي"},{"id":"q42","question":"سبينوزا: الرغبة هي؟","options":["جوهر الإنسان","عيب","مرض","فضيلة ثانوية"],"correctAnswer":0,"category":"الرغبة"},{"id":"q43","question":"الإدراك الحسي يصبح وعياً بـ؟","options":["الانتباه","اللاوعي","النوم","الحدس"],"correctAnswer":0,"category":"الوعي واللاوعي"},{"id":"q44","question":"الرغبة تختلف عن الحاجة الجسدية؟","options":["نعم","لا","نفسها","جزئياً"],"correctAnswer":0,"category":"الرغبة"},{"id":"q45","question":"فرويد: الأنا في بيته سيّد؟","options":["نعم","لا","جزئياً","مطلق"],"correctAnswer":1,"category":"الوعي واللاوعي"},{"id":"q46","question":"الرغبة قوة دافعة للحياة؟","options":["نعم","لا","سلبية","محايدة"],"correctAnswer":0,"category":"الرغبة"},{"id":"q47","question":"اللاوعي غير واعٍ بـ؟","options":["السلوكيات","المنطق","الرياضة","الأكل"],"correctAnswer":0,"category":"الوعي واللاوعي"},{"id":"q48","question":"سبينوزا يميز الرغبة عن؟","options":["الحاجة","الخوف","الحب","الكره"],"correctAnswer":0,"category":"الرغبة"},{"id":"q49","question":"الوعي يبدأ بالحواس؟","options":["نعم","لا","بالعقل","بالحدس"],"correctAnswer":0,"category":"الوعي واللاوعي"}